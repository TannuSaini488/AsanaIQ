rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function role() {
      return request.auth.token.role;
    }

    function isAdmin() {
      return isSignedIn() && role() == 'admin';
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /studentProfiles/{userId} {
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /trainerProfiles/{userId} {
      allow read: if true;
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());

      match /availability/{slotId} {
        allow read: if true;
        allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      }
    }

    match /sessions/{sessionId} {
      allow read, write: if isSignedIn();
    }

    match /chats/{chatId} {
      allow read, write: if isSignedIn();
      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /aiReports/{reportId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
